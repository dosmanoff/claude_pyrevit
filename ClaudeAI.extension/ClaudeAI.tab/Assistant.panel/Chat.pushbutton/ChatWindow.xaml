<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Claude — Revit assistant"
    Height="640" Width="760"
    WindowStartupLocation="CenterOwner"
    Background="#FAFAFA">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="ChatScroll"
                      Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12"
                      Background="White"
                      BorderBrush="#DDD"
                      BorderThickness="0,0,0,1">
            <StackPanel x:Name="ChatLog"/>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox"
                     Grid.Column="0"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="60"
                     MaxHeight="160"
                     VerticalScrollBarVisibility="Auto"
                     FontSize="13"
                     Padding="6"
                     VerticalAlignment="Stretch"/>
            <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,0,0">
                <Button x:Name="SendButton"
                        Content="Send"
                        Width="90"
                        Height="32"
                        FontWeight="SemiBold"
                        IsDefault="True"/>
                <Button x:Name="ClearButton"
                        Content="Clear"
                        Width="90"
                        Height="24"
                        Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <StatusBar Grid.Row="2" Background="#EEE">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" FontSize="11"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="TokensText"
                           Text="tokens: 0 in / 0 out  cache: 0r / 0w"
                           FontSize="11"
                           Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
